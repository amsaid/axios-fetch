{
  "name": "sd-axios-fetch",
  "version": "0.0.8",
  "description": "A zero-dependency, drop-in replacement for Axios.js built entirely on the native Fetch API. Full API compatibility with modern web standards.",
  "main": "dist/sd-axios-fetch.js",
  "module": "dist/sd-axios-fetch.mjs",
  "types": "dist/sd-axios-fetch.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/sd-axios-fetch.d.ts",
        "default": "./dist/sd-axios-fetch.mjs"
      },
      "require": {
        "types": "./dist/sd-axios-fetch.d.ts",
        "default": "./dist/sd-axios-fetch.js"
      },
      "default": "./dist/sd-axios-fetch.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "node test/test.js",
    "lint": "eslint src/ test/",
    "version": "node scripts/version.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "axios",
    "fetch",
    "http",
    "https",
    "request",
    "ajax",
    "promise",
    "api",
    "rest",
    "replacement",
    "drop-in",
    "compatibility",
    "zero-dependency",
    "typescript",
    "isomorphic",
    "browser",
    "node"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amsaid/axios-fetch.git"
  },
  "bugs": {
    "url": "https://github.com/amsaid/axios-fetch/issues"
  },
  "homepage": "https://github.com/amsaid/axios-fetch#readme",
  "engines": {
    "node": ">=14.17",
    "npm": ">=6.0.0"
  },
  "browserslist": [
    "chrome >= 62",
    "firefox >= 60",
    "safari >= 12",
    "edge >= 16"
  ]
}
