{
  "name": "sd-axios-fetch",
  "version": "0.0.3",
  "description": "A drop-in replacement for Axios.js built entirely on the Fetch API. Full API interoperability with zero Axios dependencies.",
  "main": "dist/sd-axios-fetch.js",
  "module": "dist/sd-axios-fetch.mjs",
  "types": "dist/sd-axios-fetch.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sd-axios-fetch.mjs",
      "require": "./dist/sd-axios-fetch.js",
      "default": "./dist/sd-axios-fetch.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "node test/test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "axios",
    "fetch",
    "http",
    "request",
    "ajax",
    "promise",
    "replacement",
    "drop-in",
    "compatibility"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "browserslist": [
    "node >= 14",
    "chrome >= 62",
    "firefox >= 60",
    "safari >= 12",
    "edge >= 16"
  ]
}
